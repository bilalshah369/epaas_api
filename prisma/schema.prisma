// E-PAAS Prisma Schema — PostgreSQL
// Step 1 bootstrap: users + roles only.
// Full schema (applications, workflow_actions, queries, decisions, appeals,
// reviews, extension_requests, notifications, etc.) added in later steps.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Roles ─────────────────────────────────────────────────────────────────────
// Lookup table for all 8 system roles (TDD §3, SRS §3.1).
model Role {
  id          String  @id @default(uuid())
  roleCode    String  @unique @map("role_code")
  roleName    String  @map("role_name")
  description String?

  users User[]

  @@map("roles")
}

// ── Users ─────────────────────────────────────────────────────────────────────
// Every person with a login — applicants and all officer types (TDD §4.1).
model User {
  id             String   @id @default(uuid())
  roleId         String   @map("role_id")
  role           Role     @relation(fields: [roleId], references: [id])
  username       String   @unique
  email          String   @unique
  passwordHash   String   @map("password_hash")
  // For Applicants: FSSAI license number used as login identifier
  licenseNumber  String?  @unique @map("license_number")
  // officeLocation is null for Applicants (TDD §4.1)
  officeLocation String?  @map("office_location")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  applications      Application[]
  queriesAsked      Query[]            @relation("QueriesAsked")
  queriesResponded  Query[]            @relation("QueriesResponded")
  documents         Document[]
  appeals           Appeal[]           @relation("AppealsByUser")
  reviews           Review[]           @relation("ReviewsByUser")
  extensionRequests ExtensionRequest[] @relation("ExtensionsByUser")

  @@map("users")
}

// ── Applications ───────────────────────────────────────────────────────────────
// One row per FSSAI product-approval application (TDD §5, SRS §4).
model Application {
  id              String    @id @default(uuid())
  referenceNumber String    @unique @map("reference_number")
  applicantId     String    @map("applicant_id")
  applicant       User      @relation(fields: [applicantId], references: [id])

  companyName     String    @map("company_name")
  address         String    @default("")
  applicationType String    @map("application_type")  // NSF | ClaimApproval | AyurvedaAahara | RPET | AnyOther
  foodCategory    String    @default("") @map("food_category")

  // Workflow stage — mirrors STAGES constants (TDD §6)
  stage           String    @default("Draft")

  // All form fields stored as JSON during draft phase; promoted to columns on submit
  formData        Json?     @map("form_data")
  // Product name extracted from formData for easy display
  productName     String?   @map("product_name")

  // EC Assessment checklist + notes saved by Expert Committee
  ecAssessment    Json?     @map("ec_assessment")

  submittedAt     DateTime? @map("submitted_at")
  rejectedAt      DateTime? @map("rejected_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  queries          Query[]
  documents        Document[]
  appeals          Appeal[]
  reviews          Review[]
  extensionRequests ExtensionRequest[]

  @@map("applications")
}

// ── Documents ──────────────────────────────────────────────────────────────────
// One row per uploaded file — links to an application + form field name.
model Document {
  id            String      @id @default(uuid())
  applicationId String      @map("application_id")
  application   Application @relation(fields: [applicationId], references: [id])
  fieldName     String      @map("field_name")     // e.g. "certOfAnalysis"
  originalName  String      @map("original_name")  // original filename from browser
  storedName    String      @map("stored_name")    // uuid-prefixed name on disk
  mimeType      String      @map("mime_type")
  size          Int                                // bytes
  uploadedById  String      @map("uploaded_by_id")
  uploadedBy    User        @relation(fields: [uploadedById], references: [id])
  uploadedAt    DateTime    @default(now()) @map("uploaded_at")

  @@map("documents")
}

// ── Queries ────────────────────────────────────────────────────────────────────
// Officer raises a query → app moves to QuerySent; applicant responds → app reverts.
// For Technical Officer queries: app moves to WithNodalOfficerA first; Nodal forwards manually.
model Query {
  id                  String      @id @default(uuid())
  applicationId       String      @map("application_id")
  application         Application @relation(fields: [applicationId], references: [id])

  text                String
  askedById           String      @map("asked_by_id")
  askedBy             User        @relation("QueriesAsked", fields: [askedById], references: [id])

  response            String?
  respondedById       String?     @map("responded_by_id")
  respondedBy         User?       @relation("QueriesResponded", fields: [respondedById], references: [id])
  respondedAt         DateTime?   @map("responded_at")

  // Stage the application was in before being reverted to QuerySent
  revertedFromStage   String      @map("reverted_from_stage")

  // Tech-officer query routing: originStage marks who raised it; nodal forwarding timestamps
  originStage          String?    @map("origin_stage")            // 'WithTechnicalOfficer' for tech queries
  nodalForwardedAt     DateTime?  @map("nodal_forwarded_at")      // null = waiting for Nodal to forward to applicant
  nodalFwdResponseAt   DateTime?  @map("nodal_fwd_response_at")   // null = waiting for Nodal to forward response to Tech

  createdAt           DateTime    @default(now()) @map("created_at")

  @@map("queries")
}

// ── Appeals ────────────────────────────────────────────────────────────────────
// Filed by Applicant after stage = Rejected. Routes to CEO (Appellate Authority).
model Appeal {
  id              String      @id @default(uuid())
  applicationId   String      @map("application_id")
  application     Application @relation(fields: [applicationId], references: [id])
  applicantId     String      @map("applicant_id")
  applicant       User        @relation("AppealsByUser", fields: [applicantId], references: [id])
  grounds         String
  // AppealPending | AppealApproved | AppealRejected
  status          String      @default("AppealPending")
  filedAt         DateTime    @default(now()) @map("filed_at")
  decisionAt      DateTime?   @map("decision_at")
  decisionRemarks String?     @map("decision_remarks")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  reviews         Review[]

  @@map("appeals")
}

// ── Reviews ────────────────────────────────────────────────────────────────────
// Filed by Applicant after appeal is rejected. Routes to Chairperson (final authority).
model Review {
  id              String      @id @default(uuid())
  applicationId   String      @map("application_id")
  application     Application @relation(fields: [applicationId], references: [id])
  appealId        String      @map("appeal_id")
  appeal          Appeal      @relation(fields: [appealId], references: [id])
  applicantId     String      @map("applicant_id")
  applicant       User        @relation("ReviewsByUser", fields: [applicantId], references: [id])
  grounds         String
  // ReviewPending | ReviewDisposed | DeadlinePassed
  status          String      @default("ReviewPending")
  filedAt         DateTime    @default(now()) @map("filed_at")
  decisionAt      DateTime?   @map("decision_at")
  decisionRemarks String?     @map("decision_remarks")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  @@map("reviews")
}

// ── Extension Requests ─────────────────────────────────────────────────────────
// Applicant requests extra time to respond to queries or submit documents.
model ExtensionRequest {
  id               String      @id @default(uuid())
  applicationId    String      @map("application_id")
  application      Application @relation(fields: [applicationId], references: [id])
  applicantId      String      @map("applicant_id")
  applicant        User        @relation("ExtensionsByUser", fields: [applicantId], references: [id])
  reason           String
  extensionDays    Int         @map("extension_days")
  contactEmail     String      @map("contact_email")
  justification    String
  // Pending | Approved | Rejected
  status           String      @default("Pending")
  authorityRemarks String?     @map("authority_remarks")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  @@map("extension_requests")
}
