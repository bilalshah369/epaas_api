# ── Server ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ───────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public
DATABASE_URL="postgresql://postgres:12345@localhost:5433/epaas_db_ak?schema=public"
#DATABASE_URL=postgresql://postgres:12345@host.docker.internal:5433/epaas_db343?schema=public
# ── JWT ────────────────────────────────────────────────────
JWT_SECRET=epaas_jwt_secret_fssai_2026_change_in_production
JWT_EXPIRES_IN=8h

# ── CORS ───────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ── File Storage ───────────────────────────────────────────
# Options: local | s3
STORAGE_TYPE=local
UPLOAD_DIR=uploads

# AWS S3 (only if STORAGE_TYPE=s3)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_BUCKET_NAME=
# AWS_REGION=

# ── Notifications ──────────────────────────────────────────
# Email (Nodemailer)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# SMS (MSG91)
# MSG91_AUTH_KEY=
# MSG91_SENDER_ID=

# SMS (Twilio — alternative)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
